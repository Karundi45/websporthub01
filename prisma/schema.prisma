generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  name                 String
  avatar               String?
  bio                  String?   
  location             String?
  pushSubscription     Json?
  createdAt            DateTime  @default(now())
  
  activities           Activity[]
  workouts             Workout[]
  groupsCreated        Group[]   @relation("GroupCreator")
  badges               Badge[]
  heartRateLogs        HeartRateLog[]

  // Relations
  followers            User[]    @relation("UserFollows")
  following            User[]    @relation("UserFollows")
  
  savedPosts           Activity[] @relation("SavedPosts")

  groupsMember         Group[]   @relation("GroupMembers")
  challenges           Challenge[] @relation("ChallengeParticipants")

  sentRequests         FriendRequest[] @relation("SentRequests")
  receivedRequests     FriendRequest[] @relation("ReceivedRequests")
  friendshipsUser1     Friendship[]    @relation("FriendshipUser1")
  friendshipsUser2     Friendship[]    @relation("FriendshipUser2")

  activityLikes        ActivityLike[]
  activityComments     ActivityComment[]

  messagesSent         Message[]       @relation("MessagesSent")
  messagesReceived     Message[]       @relation("MessagesReceived")

  groupMessages        GroupMessage[]  @relation("GroupMessages")
  groupInvitesSent     GroupInvite[]   @relation("GroupInviteSender")
  groupInvitesReceived GroupInvite[]   @relation("GroupInviteReceiver")

  goals                Goal[]
  personalBests        PersonalBest[]
  dailyTasks           DailyTask[]
  healthMetrics        HealthMetric[]
}

model Activity {
  id           String    @id @default(uuid())
  userId       String
  userName     String
  activity     String
  metrics      String
  time         DateTime  @default(now())
  likes        Int       @default(0)
  likedBy      String[]  // Array of strings (usernames or UUIDs)
  comments     Json      // JSON array of comments
  reactions    Json      // JSON map of reactions
  mediaUrls    String[]  // Array of strings
  workoutStats Json?     // Optional JSON
  storyText    String?
  location     Json?     // Optional JSON for location { type, coordinates }
  
  user         User      @relation(fields: [userId], references: [id])
  savedBy      User[]    @relation("SavedPosts")

  activityLikes ActivityLike[]
  activityComments ActivityComment[]
}

model Message {
  id         String   @id @default(uuid())
  text       String
  time       DateTime @default(now())
  readBy     String[]

  senderId   String
  receiverId String
  
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id])
}

model Workout {
  id           String   @id @default(uuid())
  userId       String
  activityType String
  distance     Float    @default(0)
  duration     Int      @default(0)
  path         Json     // JSON array of { lat, lng, time }
  startTime    DateTime
  endTime      DateTime

  user         User     @relation(fields: [userId], references: [id])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String
  createdById String
  createdAt   DateTime @default(now())
  location    Json?    // Optional JSON for { type, coordinates }

  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  members     User[]   @relation("GroupMembers")

  groupMessages GroupMessage[]
  groupInvites  GroupInvite[]
}

model Challenge {
  id           String   @id @default(uuid())
  title        String
  description  String
  type         String
  targetValue  Float
  startDate    DateTime
  endDate      DateTime
  
  participants User[]   @relation("ChallengeParticipants")
}

model Product {
  id       String @id @default(uuid())
  name     String
  price    Float
  category String
  rating   Float  @default(0)
  image    String
}

model GymProgram {
  id         String @id @default(uuid())
  title      String
  difficulty String
  duration   String
  workouts   Int
  image      String
}

model Badge {
  id         String   @id @default(uuid())
  userId     String
  title      String
  icon       String
  dateEarned DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model Establishment {
  id       String @id @default(uuid())
  name     String
  type     String
  location Json   // JSON { type: "Point", coordinates: [lng, lat] }
}

model HeartRateLog {
  id        String   @id @default(uuid())
  userId    String
  bpm       Int
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())

  sender     User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id         String   @id @default(uuid())
  user1Id    String
  user2Id    String
  createdAt  DateTime @default(now())

  user1      User     @relation("FriendshipUser1", fields: [user1Id], references: [id])
  user2      User     @relation("FriendshipUser2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])
}

model NavigationTab {
  id        String   @id @default(uuid())
  path      String   @unique
  label     String
  iconName  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
}

model ActivityLike {
  id         String   @id @default(uuid())
  activityId String
  userId     String
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
}

model ActivityComment {
  id         String   @id @default(uuid())
  activityId String
  userId     String
  text       String
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------- NEW MODELS ----------------

model Goal {
  id           String   @id @default(uuid())
  userId       String
  type         String   // e.g. "Hydration", "Distance", "Weight"
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  deadline     DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalBest {
  id         String   @id @default(uuid())
  userId     String
  type       String   // e.g. "5K Run Pace", "Bench Press", "Squat", "Total Distance"
  value      Float
  unit       String
  date       DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyTask {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  isCompleted Boolean  @default(false)
  date        DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealthMetric {
  id         String   @id @default(uuid())
  userId     String
  type       String   // e.g. "Hydration", "Weight", "Mood"
  value      Float
  unit       String
  date       DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GroupInvite {
  id         String   @id @default(uuid())
  groupId    String
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())

  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender     User     @relation("GroupInviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("GroupInviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model GroupMessage {
  id         String   @id @default(uuid())
  groupId    String
  senderId   String
  text       String
  time       DateTime @default(now())

  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender     User     @relation("GroupMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
